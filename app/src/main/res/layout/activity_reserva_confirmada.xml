<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:background="#FFFFFF"
    tools:context=".ActivityReservaConfirmada"
    android:fitsSystemWindows="true"
    >

    <!-- Ícone de Check (Sucesso) -->
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="64dp"
        android:src="@drawable/check_icon"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Reserva\nconfirmada!"
        android:textAlignment="center"
        android:fontFamily="@font/arvo_bold"
        android:textColor="#144229"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="32dp"
        android:background="@color/verde_ascija" />

    <!-- Bloco de Informações Dinâmicas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/txtConfirmacaoQuadra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quadra de tênis 1"
            android:fontFamily="@font/arvo"
            android:textColor="#144229"
            android:textSize="23sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtConfirmacaoDia"
            android:fontFamily="@font/arvo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dia: 15 de Junho"
            android:textColor="#144229"
            android:textSize="23sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtConfirmacaoHorario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/arvo"
            android:text="Horário: 10h - 12h"
            android:textColor="#144229"
            android:textSize="23sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Espaçador -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Botão Home -->
    <Button
        android:id="@+id/btnVoltarInicio"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Voltar ao início"
        android:backgroundTint="#144229"
        android:textSize="25sp"
        android:textStyle="bold"
        app:cornerRadius="8dp" />

</LinearLayout>