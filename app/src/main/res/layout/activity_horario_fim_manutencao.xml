<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ActivityHorarioFimManutencao"
    android:fitsSystemWindows="true"
    >

    <!-- Inicio cabecalho -->
    <LinearLayout
        android:id="@+id/linearLayoutHeader"
        android:layout_width="match_parent"
        android:layout_height="53dp"
        android:background="@color/verde_ascija"
        android:gravity="end"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageViewHomeIcon"
            android:layout_width="51dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:layout_constraintBottom_toBottomOf="@+id/linearLayoutHeader"
            app:layout_constraintEnd_toEndOf="@+id/linearLayoutHeader"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/logout_icon" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/secaoAbaixoTopo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/linearLayoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/linearLayoutHeader">

            <ImageView
                android:id="@+id/imageViewBackPage"
                android:layout_width="50dp"
                android:layout_height="38dp"
                app:layout_constraintBottom_toBottomOf="@+id/linearLayoutEndHeader"
                app:layout_constraintEnd_toStartOf="@+id/textView"
                app:layout_constraintHorizontal_bias="0.277"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/linearLayoutHeader"
                app:layout_constraintVertical_bias="0.531"
                app:srcCompat="@drawable/back_page_arrow" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/arvo_bold"
                android:text="Horário fim"
                android:textColor="@color/verde_ascija"
                android:textSize="25sp"
                app:layout_constraintBottom_toTopOf="@+id/linearLayoutEndHeader"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/linearLayoutHeader"
                app:layout_constraintVertical_bias="0.531" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayoutEndHeader"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/verde_ascija"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView"
            app:layout_constraintVertical_bias="0.015" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/containerData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="20dp"
        android:background="@drawable/background_input_borda"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/secaoAbaixoTopo"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="400dp">

        <TextView
            android:id="@+id/txtDataSelecionada"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="15 de Junho"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/calendario"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/calendar_icon" />


    </LinearLayout>

    <TextView
        android:id="@+id/TxtVSeleionarHorario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Selecionar horário"
        android:textColor="#144229"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/containerData"
        tools:layout_editor_absoluteY="206dp"

        />

    <!-- GRADE DE HORÁRIOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHorarios"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:layout_weight="1"
        android:alignmentMode="alignBounds"
        android:padding="8dp"
        android:rowOrderPreserved="false"
        tools:layout_editor_absoluteY="249dp"
        app:layout_constraintTop_toBottomOf="@id/TxtVSeleionarHorario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:foregroundGravity="center"
        />

    <!-- RODAPÉ FIXO -->

    <LinearLayout
        android:id="@+id/rodape"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rvHorarios">

        <View
            android:id="@+id/view"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            app:layout_constraintBottom_toTopOf="@+id/txtResumoSelecao"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rvHorarios" />

        <TextView
            android:id="@+id/txtResumoSelecao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Horário selecionado: 00:00 - 00:00"
            android:textSize="13dp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/btnConfirmar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rvHorarios" />

        <Button
            android:id="@+id/btnConfirmar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="16dp"
            android:backgroundTint="#144229"
            android:fontFamily="@font/arvo_bold"
            android:text="Confirmar"
            android:textSize="20dp"
            app:cornerRadius="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.312"
            app:layout_constraintStart_toStartOf="parent" />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>